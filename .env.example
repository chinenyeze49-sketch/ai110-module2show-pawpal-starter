# Copy to .env and fill in for real LLM calls. Without these, PawPal+ uses
# the deterministic mock provider so everything still works offline.

# Pick one: "mock" (default), "anthropic", or "openai"
PAWPAL_AI_PROVIDER=mock

# Provider-specific (only set the one matching PAWPAL_AI_PROVIDER)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional override
# PAWPAL_AI_MODEL=claude-haiku-4-5-20251001
# PAWPAL_LOG_DIR=logs
